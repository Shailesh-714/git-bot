{
  "name": "@shailesh-714/git-bot",
  "version": "0.1.0",
  "description": "git-bot: an LLM-powered CLI assistant for conventional commits and branch names.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:bundle": "node scripts/build.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "keywords": [
    "git",
    "cli",
    "commit",
    "branch",
    "llm",
    "conventional-commits",
    "langgraph"
  ],
  "author": "Shailesh-714",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shailesh-714/git-bot.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.3.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0",
    "smol-toml": "^1.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
